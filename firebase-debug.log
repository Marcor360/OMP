[debug] [2026-04-30T17:34:05.591Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/ormeprassig-public/rulesets {"name":"projects/ormeprassig-public/rulesets/176b4251-a30e-41e0-ab60-cb69665e9d62","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    // =========================================================================\n    // AUTENTICACIÓN Y USUARIO ACTUAL\n    // =========================================================================\n\n    function isAuthenticated() {\n      return request.auth != null;\n    }\n\n    function currentUid() {\n      return request.auth != null ? request.auth.uid : null;\n    }\n\n    function currentUserPath() {\n      return /databases/$(database)/documents/users/$(currentUid());\n    }\n\n    function hasCurrentUserDoc() {\n      return isAuthenticated() && exists(currentUserPath());\n    }\n\n    function currentUserData() {\n      return get(currentUserPath()).data;\n    }\n\n    // =========================================================================\n    // VALIDACIONES BASE\n    // =========================================================================\n\n    function isNonEmptyString(value) {\n      return value is string && value.size() > 0;\n    }\n\n    function isValidRole(role) {\n      return role is string && role in ['admin', 'supervisor', 'user'];\n    }\n\n    function hasOnlyKeys(data, allowed) {\n      return data.keys().hasOnly(allowed);\n    }\n\n    function hasAllKeys(data, required) {\n      return data.keys().hasAll(required);\n    }\n\n    function sameKeysOnUpdate(allowedChangedKeys) {\n      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedChangedKeys);\n    }\n\n    function preservesCreatedAt() {\n      return !('createdAt' in resource.data) || request.resource.data.createdAt == resource.data.createdAt;\n    }\n\n    // =========================================================================\n    // ESTADO DEL USUARIO ACTUAL\n    // =========================================================================\n\n    function currentUserHasRequiredShape() {\n      return hasCurrentUserDoc()\n        && isNonEmptyString(currentUserData().email)\n        && isValidRole(currentUserData().role)\n        && isNonEmptyString(currentUserData().congregationId)\n        && currentUserData().isActive is bool;\n    }\n\n    function isActive() {\n      return currentUserHasRequiredShape()\n        && currentUserData().isActive == true;\n    }\n\n    function isAdmin() {\n      return isActive() && currentUserData().role == 'admin';\n    }\n\n    function isSupervisor() {\n      return isActive() && currentUserData().role == 'supervisor';\n    }\n\n    function isAdminOrSupervisor() {\n      return isAdmin() || isSupervisor();\n    }\n\n    function isCleaningManager() {\n      return isAdminOrSupervisor()\n        || (\n          isActive()\n          && currentUserData().servicePosition == 'encargado'\n          && (\n            !('serviceDepartment' in currentUserData())\n            || currentUserData().serviceDepartment == 'limpieza'\n          )\n        );\n    }\n\n    function isSameUser(userId) {\n      return isAuthenticated() && currentUid() == userId;\n    }\n\n    function myCongregationId() {\n      return hasCurrentUserDoc() ? currentUserData().congregationId : null;\n    }\n\n    function sameCongregation(congregationId) {\n      return isActive()\n        && isNonEmptyString(congregationId)\n        && myCongregationId() == congregationId;\n    }\n\n    function storedDocInMyCongregation() {\n      return resource.data.congregationId is string\n        && sameCongregation(resource.data.congregationId);\n    }\n\n    function targetDocInMyCongregation() {\n      return request.resource.data.congregationId is string\n        && sameCongregation(request.resource.data.congregationId);\n    }\n\n    // =========================================================================\n    // USERS\n    // =========================================================================\n\n    function allowedUserKeys() {\n      return [\n        'uid',\n        'email',\n        'firstName',\n        'middleName',\n        'lastName',\n        'secondLastName',\n        'displayName',\n        'phone',\n        'photoURL',\n        'role',\n        'isActive',\n        // 'status' es gestionado exclusivamente por Cloud Functions (createUserByAdmin / updateUserByAdmin).\n        // Se incluye aquí para que validUserData no rechace documentos que ya lo contienen\n        // cuando el cliente realiza actualizaciones parciales.\n        'status',\n        'congregationId',\n        'congregationDomain',\n        // Campos de asignación de servicio — escritura por Cloud Functions.\n        'servicePosition',\n        'serviceDepartment',\n        'department',\n        'createdAt',\n        'updatedAt',\n        // Campos de notificaciones push — escritura controlada por validPushTokenUpdate()\n        'notificationTokens',\n        'pushTokenUpdatedAt',\n        // Campos de preferencias de notificación\n        'notificationsEnabled',\n        'platformNotifications',\n        'cleaningNotifications',\n        'hospitalityNotifications',\n        // Campos de módulo de limpieza\n        'cleaningEligible',\n        'cleaningGroupId',\n        'cleaningGroupName'\n      ];\n    }\n\n    function requiredUserKeys() {\n      return [\n        'email',\n        'firstName',\n        'lastName',\n        'role',\n        'isActive',\n        'congregationId'\n      ];\n    }\n\n    function validUserData(data, userId) {\n      return hasOnlyKeys(data, allowedUserKeys())\n        && hasAllKeys(data, requiredUserKeys())\n        && isNonEmptyString(data.email)\n        && isNonEmptyString(data.firstName)\n        && isNonEmptyString(data.lastName)\n        && isValidRole(data.role)\n        && data.isActive is bool\n        && isNonEmptyString(data.congregationId)\n        && (\n          !('uid' in data)\n          || (data.uid is string && data.uid == userId)\n        )\n        && (\n          !('displayName' in data)\n          || data.displayName is string\n        )\n        && (\n          !('phone' in data)\n          || data.phone is string\n        )\n        && (\n          !('photoURL' in data)\n          || data.photoURL is string\n        )\n        && (\n          !('notificationTokens' in data)\n          || data.notificationTokens is list\n        )\n        && (\n          !('pushTokenUpdatedAt' in data)\n          || data.pushTokenUpdatedAt is timestamp\n        )\n        && (\n          !('cleaningEligible' in data)\n          || data.cleaningEligible is bool\n        )\n        && (\n          !('cleaningGroupId' in data)\n          || data.cleaningGroupId == null\n          || data.cleaningGroupId is string\n        )\n        && (\n          !('cleaningGroupName' in data)\n          || data.cleaningGroupName == null\n          || data.cleaningGroupName is string\n        );\n    }\n\n    function validUserCreate(userId) {\n      return validUserData(request.resource.data, userId);\n    }\n\n    function validUserUpdateByAdmin(userId) {\n      return validUserData(request.resource.data, userId)\n        && preservesCreatedAt();\n    }\n\n    function validSelfUserUpdate(userId) {\n      return isSameUser(userId)\n        && validUserData(request.resource.data, userId)\n        && request.resource.data.email == resource.data.email\n        && request.resource.data.role == resource.data.role\n        && request.resource.data.isActive == resource.data.isActive\n        && request.resource.data.congregationId == resource.data.congregationId\n        && preservesCreatedAt()\n        && sameKeysOnUpdate([\n          'firstName',\n          'lastName',\n          'displayName',\n          'phone',\n          'photoURL',\n          'updatedAt'\n        ]);\n    }\n\n    // Permite al propio usuario actualizar SOLO su token de notificación push.\n    // El cliente llama setDoc(..., { uid, notificationTokens: arrayUnion(token),\n    //   pushTokenUpdatedAt: serverTimestamp(), updatedAt: serverTimestamp() }, { merge: true }).\n    // Esta condición es independiente de validSelfUserUpdate para no interferir\n    // con las validaciones de perfil.\n    function validPushTokenUpdate(userId) {\n      return isSameUser(userId)\n        && isActive()\n        && sameKeysOnUpdate(['notificationTokens', 'pushTokenUpdatedAt', 'updatedAt', 'uid']);\n    }\n\n    function isValidEventType(type) {\n      return type in [\n        'conmemoracion',\n        'asamblea_circuito',\n        'asamblea_regional',\n        'visita_superintendente',\n        'reunion_especial',\n        'capacitacion'\n      ];\n    }\n\n    function validEventData(data) {\n      return hasOnlyKeys(data, [\n          'congregationId',\n          'type',\n          'title',\n          'superintendentName',\n          'superintendentWifeName',\n          'startDate',\n          'endDate',\n          'deleteAt',\n          'location',\n          'color',\n          'createdBy',\n          'updatedBy',\n          'createdAt',\n          'updatedAt'\n        ])\n        && data.congregationId == myCongregationId()\n        && isValidEventType(data.type)\n        && data.startDate is timestamp\n        && data.endDate is timestamp\n        && data.deleteAt is timestamp\n        && data.color is string\n        && data.createdBy is string\n        && data.createdAt is timestamp\n        && data.updatedAt is timestamp\n        && (\n          !('updatedBy' in data)\n          || data.updatedBy is string\n        )\n        && (\n          !('location' in data)\n          || data.location is string\n        )\n        && (\n          !('superintendentWifeName' in data)\n          || data.superintendentWifeName is string\n        )\n        && (\n          data.type == 'visita_superintendente'\n          ? (\n            isNonEmptyString(data.superintendentName)\n            && !('title' in data)\n          )\n          : (\n            isNonEmptyString(data.title)\n            && !('superintendentName' in data)\n            && !('superintendentWifeName' in data)\n          )\n        );\n    }\n\n    function validEventCreate() {\n      return isAdminOrSupervisor()\n        && validEventData(request.resource.data)\n        && request.resource.data.createdBy == currentUid();\n    }\n\n    function validEventUpdate() {\n      return isAdminOrSupervisor()\n        && resource.data.congregationId == myCongregationId()\n        && validEventData(request.resource.data)\n        && request.resource.data.createdBy == resource.data.createdBy\n        && request.resource.data.createdAt == resource.data.createdAt;\n    }\n\n    function validExpoPushTokenDoc(userId) {\n      return isSameUser(userId)\n        && isActive()\n        && hasOnlyKeys(request.resource.data, [\n          'token',\n          'userId',\n          'congregationId',\n          'platform',\n          'deviceName',\n          'isActive',\n          'updatedAt'\n        ])\n        && isNonEmptyString(request.resource.data.token)\n        && request.resource.data.userId == userId\n        && request.resource.data.congregationId == currentUserData().congregationId\n        && request.resource.data.platform in ['ios', 'android']\n        && (\n          request.resource.data.deviceName == null\n          || request.resource.data.deviceName is string\n        )\n        && request.resource.data.isActive is bool\n        && request.resource.data.updatedAt is timestamp;\n    }\n\n    function validCleaningMembershipUserUpdate() {\n      return isCleaningManager()\n        && storedDocInMyCongregation()\n        && targetDocInMyCongregation()\n        && preservesCreatedAt()\n        && request.resource.data.email == resource.data.email\n        && request.resource.data.role == resource.data.role\n        && request.resource.data.isActive == resource.data.isActive\n        && request.resource.data.congregationId == resource.data.congregationId\n        && (\n          !('cleaningGroupId' in request.resource.data)\n          || request.resource.data.cleaningGroupId == null\n          || request.resource.data.cleaningGroupId is string\n        )\n        && (\n          !('cleaningGroupName' in request.resource.data)\n          || request.resource.data.cleaningGroupName == null\n          || request.resource.data.cleaningGroupName is string\n        )\n        && sameKeysOnUpdate([\n          'cleaningGroupId',\n          'cleaningGroupName',\n          'updatedAt'\n        ]);\n    }\n\n    // =========================================================================\n    // CONGREGATIONS\n    // =========================================================================\n\n    function allowedCongregationKeys() {\n      return [\n        'name',\n        'code',\n        'country',\n        'state',\n        'city',\n        'language',\n        'timezone',\n        'isActive',\n        'createdAt',\n        'updatedAt'\n      ];\n    }\n\n    function validCongregationData(data) {\n      return hasOnlyKeys(data, allowedCongregationKeys())\n        && hasAllKeys(data, ['name', 'isActive'])\n        && isNonEmptyString(data.name)\n        && data.isActive is bool\n        && (!('code' in data) || data.code is string)\n        && (!('country' in data) || data.country is string)\n        && (!('state' in data) || data.state is string)\n        && (!('city' in data) || data.city is string)\n        && (!('language' in data) || data.language is string)\n        && (!('timezone' in data) || data.timezone is string);\n    }\n\n    // =========================================================================\n    // PERSONS\n    // =========================================================================\n\n    function allowedPersonKeys() {\n      return [\n        'congregationId',\n        'firstName',\n        'lastName',\n        'displayName',\n        'gender',\n        'phone',\n        'email',\n        'isBaptized',\n        'isPublisher',\n        'isActive',\n        'notes',\n        'createdAt',\n        'updatedAt'\n      ];\n    }\n\n    function validPersonData(data, congregationId) {\n      return hasOnlyKeys(data, allowedPersonKeys())\n        && hasAllKeys(data, ['congregationId', 'firstName', 'lastName', 'isActive'])\n        && data.congregationId == congregationId\n        && isNonEmptyString(data.firstName)\n        && isNonEmptyString(data.lastName)\n        && data.isActive is bool\n        && (!('displayName' in data) || data.displayName is string)\n        && (!('gender' in data) || data.gender is string)\n        && (!('phone' in data) || data.phone is string)\n        && (!('email' in data) || data.email is string)\n        && (!('isBaptized' in data) || data.isBaptized is bool)\n        && (!('isPublisher' in data) || data.isPublisher is bool)\n        && (!('notes' in data) || data.notes is string);\n    }\n\n    // =========================================================================\n    // MEETINGS\n    // =========================================================================\n\n    function allowedMeetingKeys() {\n      return [\n        'congregationId',\n        'type',\n        'meetingCategory',\n        'title',\n        'description',\n        'date',\n        'status',\n        'notes',\n        'createdAt',\n        'updatedAt'\n      ];\n    }\n\n    function validMeetingType(value) {\n      return value is string\n        && value in ['midweek', 'weekend', 'cleaning', 'hospitality'];\n    }\n\n    function validMeetingData(data, congregationId) {\n      return hasOnlyKeys(data, allowedMeetingKeys())\n        && hasAllKeys(data, ['congregationId', 'type', 'date'])\n        && data.congregationId == congregationId\n        && validMeetingType(data.type)\n        && isNonEmptyString(data.date)\n        && (!('meetingCategory' in data) || data.meetingCategory is string)\n        && (!('title' in data) || data.title is string)\n        && (!('description' in data) || data.description is string)\n        && (!('status' in data) || data.status is string)\n        && (!('notes' in data) || data.notes is string);\n    }\n\n    // =========================================================================\n    // ASSIGNMENTS\n    // =========================================================================\n\n    function allowedAssignmentKeys() {\n      return [\n        'congregationId',\n        'meetingId',\n        'category',\n        'type',\n        'section',\n        'title',\n        'description',\n        'priority',\n        'assignedToUid',\n        'assignedByUid',\n        'assignedByName',\n        'createdBy',\n        'updatedBy',\n        'cleaningGroupId',\n        'cleaningGroupName',\n        'assignedUsers',\n        'date',\n        'dueDate',\n        'assignedToUserId',\n        'assignedToPersonId',\n        'assignedToName',\n        'assistantUserId',\n        'assistantPersonId',\n        'assistantName',\n        'startTime',\n        'endTime',\n        'durationMinutes',\n        'status',\n        'notes',\n        'createdAt',\n        'updatedAt'\n      ];\n    }\n\n    function validAssignmentData(data, congregationId, meetingId) {\n      return hasOnlyKeys(data, allowedAssignmentKeys())\n        && hasAllKeys(data, ['congregationId', 'meetingId', 'type', 'title'])\n        && data.congregationId == congregationId\n        && data.meetingId == meetingId\n        && isNonEmptyString(data.type)\n        && isNonEmptyString(data.title)\n        && (!('category' in data) || data.category is string)\n        && (!('section' in data) || data.section is string)\n        && (!('description' in data) || data.description is string)\n        && (!('priority' in data) || data.priority is string)\n        && (!('assignedToUid' in data) || data.assignedToUid is string)\n        && (!('assignedByUid' in data) || data.assignedByUid is string)\n        && (!('assignedByName' in data) || data.assignedByName is string)\n        && (!('createdBy' in data) || data.createdBy is string)\n        && (!('updatedBy' in data) || data.updatedBy is string)\n        && (!('cleaningGroupId' in data) || data.cleaningGroupId is string)\n        && (!('cleaningGroupName' in data) || data.cleaningGroupName is string)\n        && (!('assignedUsers' in data) || data.assignedUsers is list)\n        && (!('assignedToUserId' in data) || data.assignedToUserId is string)\n        && (!('assignedToPersonId' in data) || data.assignedToPersonId is string)\n        && (!('assignedToName' in data) || data.assignedToName is string)\n        && (!('assistantUserId' in data) || data.assistantUserId is string)\n        && (!('assistantPersonId' in data) || data.assistantPersonId is string)\n        && (!('assistantName' in data) || data.assistantName is string)\n        && (!('startTime' in data) || data.startTime is string)\n        && (!('endTime' in data) || data.endTime is string)\n        && (!('durationMinutes' in data) || data.durationMinutes is int)\n        && (!('status' in data) || data.status is string)\n        && (!('notes' in data) || data.notes is string);\n    }\n\n    function validStandaloneAssignmentData(data, congregationId) {\n      return hasOnlyKeys(data, allowedAssignmentKeys())\n        && hasAllKeys(data, ['congregationId', 'category', 'type', 'title'])\n        && data.congregationId == congregationId\n        && isNonEmptyString(data.category)\n        && isNonEmptyString(data.type)\n        && isNonEmptyString(data.title)\n        && (!('meetingId' in data) || data.meetingId is string)\n        && (!('section' in data) || data.section is string)\n        && (!('description' in data) || data.description is string)\n        && (!('priority' in data) || data.priority is string)\n        && (!('assignedToUid' in data) || data.assignedToUid is string)\n        && (!('assignedByUid' in data) || data.assignedByUid is string)\n        && (!('assignedByName' in data) || data.assignedByName is string)\n        && (!('createdBy' in data) || data.createdBy is string)\n        && (!('updatedBy' in data) || data.updatedBy is string)\n        && (!('cleaningGroupId' in data) || data.cleaningGroupId is string)\n        && (!('cleaningGroupName' in data) || data.cleaningGroupName is string)\n        && (!('assignedUsers' in data) || data.assignedUsers is list)\n        && (!('assignedToUserId' in data) || data.assignedToUserId is string)\n        && (!('assignedToPersonId' in data) || data.assignedToPersonId is string)\n        && (!('assignedToName' in data) || data.assignedToName is string)\n        && (!('assistantUserId' in data) || data.assistantUserId is string)\n        && (!('assistantPersonId' in data) || data.assistantPersonId is string)\n        && (!('assistantName' in data) || data.assistantName is string)\n        && (!('startTime' in data) || data.startTime is string)\n        && (!('endTime' in data) || data.endTime is string)\n        && (!('durationMinutes' in data) || data.durationMinutes is int)\n        && (!('status' in data) || data.status is string)\n        && (!('notes' in data) || data.notes is string);\n    }\n\n    // =========================================================================\n    // CLEANING GROUPS\n    // =========================================================================\n\n    function allowedCleaningGroupKeys() {\n      return [\n        'name',\n        'description',\n        'congregationId',\n        'groupType',\n        'memberIds',\n        'memberCount',\n        'isActive',\n        'createdBy',\n        'createdAt',\n        'updatedAt'\n      ];\n    }\n\n    function validCleaningGroupData(data, congregationId) {\n      return hasOnlyKeys(data, allowedCleaningGroupKeys())\n        && hasAllKeys(data, [\n          'name',\n          'congregationId',\n          'groupType',\n          'memberIds',\n          'memberCount',\n          'isActive',\n          'createdBy',\n          'createdAt',\n          'updatedAt'\n        ])\n        && data.congregationId == congregationId\n        && isNonEmptyString(data.name)\n        && data.name.size() <= 80\n        && data.groupType in ['standard', 'family']\n        && data.memberIds is list\n        && data.memberIds.size() <= 200\n        && data.memberCount is int\n        && data.memberCount >= 0\n        && data.memberCount <= 200\n        && data.memberCount == data.memberIds.size()\n        && data.isActive is bool\n        && data.createdBy is string\n        && data.createdAt is timestamp\n        && data.updatedAt is timestamp\n        && (!('description' in data) || (data.description is string && data.description.size() <= 300));\n    }\n\n    // =========================================================================\n    // NOTIFICATIONS\n    // =========================================================================\n\n    function allowedNotificationKeys() {\n      return [\n        'congregationId',\n        'userId',\n        'title',\n        'body',\n        'type',\n        'isRead',\n        'relatedId',\n        'createdAt',\n        'readAt'\n      ];\n    }\n\n    function validNotificationData(data, congregationId) {\n      return hasOnlyKeys(data, allowedNotificationKeys())\n        && hasAllKeys(data, ['congregationId', 'title', 'body', 'type', 'isRead'])\n        && data.congregationId == congregationId\n        && isNonEmptyString(data.title)\n        && isNonEmptyString(data.body)\n        && isNonEmptyString(data.type)\n        && data.isRead is bool\n        && (!('userId' in data) || data.userId is string)\n        && (!('relatedId' in data) || data.relatedId is string);\n    }\n\n    // =========================================================================\n    // CHANGE LOGS\n    // =========================================================================\n\n    function allowedChangeLogKeys() {\n      return [\n        'congregationId',\n        'actorUserId',\n        'actorName',\n        'action',\n        'entityType',\n        'entityId',\n        'description',\n        'metadata',\n        'createdAt'\n      ];\n    }\n\n    function validChangeLogData(data, congregationId) {\n      return hasOnlyKeys(data, allowedChangeLogKeys())\n        && hasAllKeys(data, ['congregationId', 'actorUserId', 'action', 'entityType', 'entityId', 'createdAt'])\n        && data.congregationId == congregationId\n        && data.actorUserId == currentUid()\n        && isNonEmptyString(data.action)\n        && isNonEmptyString(data.entityType)\n        && isNonEmptyString(data.entityId)\n        && (!('actorName' in data) || data.actorName is string)\n        && (!('description' in data) || data.description is string)\n        && (!('metadata' in data) || data.metadata is map);\n    }\n\n    // =========================================================================\n    // REGLAS: SYSTEM\n    // Solo lectura para usuarios autenticados.\n    // Usado por cache-control-service.ts para leer system/cacheControl.\n    // Escritura reservada exclusivamente para Cloud Functions / consola admin.\n    // =========================================================================\n\n    match /system/{docId} {\n      allow read: if isAuthenticated();\n      allow write: if false;\n    }\n\n    // =========================================================================\n    // REGLAS: USERS\n    // =========================================================================\n\n    match /events/{eventId} {\n      allow get, list: if isActive()\n        && resource.data.congregationId == myCongregationId();\n      allow create: if validEventCreate();\n      allow update: if validEventUpdate();\n      allow delete: if isAdminOrSupervisor()\n        && resource.data.congregationId == myCongregationId();\n    }\n\n    match /users/{userId} {\n      allow get: if isSameUser(userId)\n        || (isCleaningManager() && storedDocInMyCongregation());\n\n      // list sólo dentro de la propia congregación.\n      // Firestore Security Rules no permiten inspeccionar filtros de query,\n      // por lo que la restricción real se aplica en la app (siempre filtra por congregationId).\n      // myCongregationId() != null garantiza que el solicitante tiene perfil activo con congregación.\n      allow list: if isCleaningManager() && myCongregationId() != null;\n\n      allow create: if isAdmin()\n        && validUserCreate(userId)\n        && targetDocInMyCongregation();\n\n      allow update: if (\n          isAdmin()\n          && storedDocInMyCongregation()\n          && targetDocInMyCongregation()\n          && validUserUpdateByAdmin(userId)\n        ) || (\n          validSelfUserUpdate(userId)\n        ) || (\n          // Registro de token push: el propio usuario actualiza SOLO su token.\n          // Llamado desde registerPushTokenForUser() en notifications-service.ts.\n          validPushTokenUpdate(userId)\n        ) || (\n          // Gestion de grupos de limpieza: solo campos de membresia de limpieza.\n          validCleaningMembershipUserUpdate()\n        );\n\n      allow delete: if isAdmin() && storedDocInMyCongregation();\n\n      match /pushTokens/{tokenDocId} {\n        allow get, list: if isSameUser(userId);\n        allow create, update: if validExpoPushTokenDoc(userId);\n        allow delete: if isSameUser(userId);\n      }\n    }\n\n    // =========================================================================\n    // REGLAS: CONGREGATIONS\n    // =========================================================================\n\n    match /congregations/{congregationId} {\n      allow get: if sameCongregation(congregationId);\n      allow list: if false;\n\n      allow create: if isAdmin()\n        && sameCongregation(congregationId)\n        && validCongregationData(request.resource.data);\n\n      allow update: if isAdmin()\n        && sameCongregation(congregationId)\n        && validCongregationData(request.resource.data)\n        && preservesCreatedAt();\n\n      allow delete: if false;\n\n      // -----------------------------------------------------------------------\n      // PERSONS\n      // -----------------------------------------------------------------------\n      match /persons/{personId} {\n        allow get, list: if sameCongregation(congregationId);\n\n        allow create: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validPersonData(request.resource.data, congregationId);\n\n        allow update: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validPersonData(request.resource.data, congregationId)\n          && preservesCreatedAt();\n\n        allow delete: if isAdmin();\n      }\n\n      // -----------------------------------------------------------------------\n      // MEETINGS\n      // -----------------------------------------------------------------------\n      match /meetings/{meetingId} {\n        allow get, list: if sameCongregation(congregationId);\n\n        allow create: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validMeetingData(request.resource.data, congregationId);\n\n        allow update: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validMeetingData(request.resource.data, congregationId)\n          && preservesCreatedAt();\n\n        allow delete: if isAdmin();\n\n        // ---------------------------------------------------------------------\n        // ASSIGNMENTS\n        // ---------------------------------------------------------------------\n        match /assignments/{assignmentId} {\n          allow get, list: if sameCongregation(congregationId);\n\n          allow create: if isAdminOrSupervisor()\n            && sameCongregation(congregationId)\n            && validAssignmentData(request.resource.data, congregationId, meetingId);\n\n          allow update: if isAdminOrSupervisor()\n            && sameCongregation(congregationId)\n            && validAssignmentData(request.resource.data, congregationId, meetingId)\n            && preservesCreatedAt();\n\n          allow delete: if isAdmin();\n        }\n      }\n\n      // -----------------------------------------------------------------------\n      // ASSIGNMENTS (congregation scoped: limpieza, hospitalidad u otras tareas)\n      // -----------------------------------------------------------------------\n      match /assignments/{assignmentId} {\n        allow get, list: if sameCongregation(congregationId);\n\n        allow create: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validStandaloneAssignmentData(request.resource.data, congregationId);\n\n        allow update: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validStandaloneAssignmentData(request.resource.data, congregationId)\n          && preservesCreatedAt();\n\n        allow delete: if isAdmin();\n      }\n\n      // -----------------------------------------------------------------------\n      // CLEANING GROUPS\n      // -----------------------------------------------------------------------\n      match /cleaningGroups/{groupId} {\n        allow get, list: if sameCongregation(congregationId);\n\n        allow create: if isCleaningManager()\n          && sameCongregation(congregationId)\n          && validCleaningGroupData(request.resource.data, congregationId);\n\n        allow update: if isCleaningManager()\n          && sameCongregation(congregationId)\n          && resource.data.congregationId == congregationId\n          && validCleaningGroupData(request.resource.data, congregationId)\n          && preservesCreatedAt();\n\n        allow delete: if isAdmin()\n          && sameCongregation(congregationId)\n          && resource.data.congregationId == congregationId;\n      }\n\n      // Compatibilidad con el nombre legacy usado por versiones anteriores.\n      match /cleaning_groups/{groupId} {\n        allow get, list: if sameCongregation(congregationId);\n\n        allow create: if isCleaningManager()\n          && sameCongregation(congregationId)\n          && validCleaningGroupData(request.resource.data, congregationId);\n\n        allow update: if isCleaningManager()\n          && sameCongregation(congregationId)\n          && resource.data.congregationId == congregationId\n          && validCleaningGroupData(request.resource.data, congregationId)\n          && preservesCreatedAt();\n\n        allow delete: if isAdmin()\n          && sameCongregation(congregationId)\n          && resource.data.congregationId == congregationId;\n      }\n\n      // -----------------------------------------------------------------------\n      // NOTIFICATIONS\n      // -----------------------------------------------------------------------\n      match /notifications/{notificationId} {\n        allow get: if sameCongregation(congregationId)\n          && (\n            !('userId' in resource.data)\n            || resource.data.userId == currentUid()\n            || isAdminOrSupervisor()\n          );\n\n        allow list: if sameCongregation(congregationId) && isAdminOrSupervisor();\n\n        allow create: if isAdminOrSupervisor()\n          && sameCongregation(congregationId)\n          && validNotificationData(request.resource.data, congregationId);\n\n        allow update: if (\n            isAdminOrSupervisor()\n            && sameCongregation(congregationId)\n            && validNotificationData(request.resource.data, congregationId)\n          ) || (\n            sameCongregation(congregationId)\n            && resource.data.userId == currentUid()\n            && request.resource.data.congregationId == resource.data.congregationId\n            && request.resource.data.userId == resource.data.userId\n            && request.resource.data.title == resource.data.title\n            && request.resource.data.body == resource.data.body\n            && request.resource.data.type == resource.data.type\n            && request.resource.data.relatedId == resource.data.relatedId\n            && sameKeysOnUpdate(['isRead', 'readAt'])\n            && request.resource.data.isRead is bool\n            && (!('readAt' in request.resource.data) || request.resource.data.readAt is string)\n          );\n\n        allow delete: if isAdmin();\n      }\n\n      // -----------------------------------------------------------------------\n      // CHANGE LOGS\n      // -----------------------------------------------------------------------\n      match /changeLogs/{logId} {\n        allow get, list: if isAdminOrSupervisor() && sameCongregation(congregationId);\n\n        allow create: if isActive()\n          && sameCongregation(congregationId)\n          && validChangeLogData(request.resource.data, congregationId);\n\n        allow update, delete: if false;\n      }\n    }\n\n    // =========================================================================\n    // REGLAS: DASHBOARD SUMMARY\n    // Documento de resumen pre-calculado por Cloud Functions.\n    // Solo lectura para usuarios activos de la misma congregación.\n    // Escritura reservada exclusivamente para Cloud Functions.\n    // =========================================================================\n\n    match /dashboardSummary/{congregationId} {\n      allow read: if sameCongregation(congregationId);\n      allow write: if false;\n    }\n\n    // =========================================================================\n    // REGLAS: CLEANING GROUPS\n    // Grupos de limpieza — acceso por congregación.\n    // =========================================================================\n\n    match /cleaningGroups/{groupId} {\n      allow get: if isActive()\n        && resource.data.congregationId is string\n        && sameCongregation(resource.data.congregationId);\n\n      // list restringido a usuarios activos de la misma congregación que el documento.\n      // myCongregationId() != null garantiza que el solicitante tiene congregación asignada.\n      allow list: if isActive() && myCongregationId() != null;\n\n      allow create: if isCleaningManager()\n        && targetDocInMyCongregation()\n        && validCleaningGroupData(request.resource.data, request.resource.data.congregationId);\n\n      allow update: if isCleaningManager()\n        && storedDocInMyCongregation()\n        && targetDocInMyCongregation()\n        && validCleaningGroupData(request.resource.data, request.resource.data.congregationId)\n        && preservesCreatedAt();\n\n      allow delete: if isAdmin() && storedDocInMyCongregation();\n    }\n\n    // =========================================================================\n    // REGLAS: NOTIFICATIONS (colección raíz)\n    // Nota: las notificaciones de congregación están en\n    // /congregations/{id}/notifications. Esta colección raíz es para\n    // notificaciones globales o de sistema (si se usan).\n    // =========================================================================\n\n    match /notifications/{notificationId} {\n      allow read: if isAuthenticated()\n        && (\n          !('userId' in resource.data)\n          || resource.data.userId == currentUid()\n          || isAdminOrSupervisor()\n        );\n\n      allow create: if isAdminOrSupervisor();\n\n      allow update: if isAuthenticated()\n        && resource.data.userId == currentUid()\n        && sameKeysOnUpdate(['isRead', 'readAt']);\n\n      allow delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-30T17:34:05.887359Z","metadata":{"services":["cloud.firestore"]}}
